// ==UserScript==
// @name           PDF/PPT/TIF viewer with Google docs
// @namespace      http://d.hatena.ne.jp/Koonies/
// @match          http://*/*
// @match          https://*/*
// @exclude        *://docs.google.com/*
// @version        1.4
// ==/UserScript==

(function() {
  if (location.hostname === "docs.google.com") return;

  function isTargetUrl(url) {
    return /\.(pdf|ppt|pptx|tif|tiff)(\?|#|$)/i.test(url);
  }

  function rewriteLink(item) {
    if (!item || !item.href || item.dataset.fmzGoogleDocsViewer === "1") return;
    if (!isTargetUrl(item.href)) return;

    var ico = document.createElement("img");
    ico.src = "https://docs.google.com/favicon.ico";
    ico.style.width = "16px";
    ico.style.height = "16px";
    ico.style.marginRight = "4px";

    item.parentNode.insertBefore(ico, item);
    item.href = "https://docs.google.com/viewerng/viewer?url=" + encodeURIComponent(item.href);
    item.dataset.fmzGoogleDocsViewer = "1";
  }

  function handle(node) {
    var links = [];
    if (node && node.matches && node.matches("a")) links.push(node);
    if (node && node.querySelectorAll) {
      links = links.concat(Array.prototype.slice.call(node.querySelectorAll("a")));
    }

    links.forEach(rewriteLink);
  }

  handle(document);

  var observer = new MutationObserver(function(mutations) {
    mutations.forEach(function(mutation) {
      mutation.addedNodes.forEach(handle);
    });
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();
